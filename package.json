{
	"name": "modern-web-push",
	"version": "0.0.0",
	"description": "Runtime-agnostic Web Push library using Web Crypto API",
	"license": "MPL-2.0",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest",
		"lint": "oxlint --max-warnings=0",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"typecheck": "oxlint --max-warnings=0"
	},
	"dependencies": {
		"jose": "^6.2.2"
	},
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260326.1",
		"msw": "^2.12.14",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.4",
		"publint": "^0.3.18",
		"tsdown": "^0.21.5",
		"vitest": "^4.1.2"
	},
	"devEngines": {
		"runtime": [
			{
				"name": "node",
				"version": ">=22",
				"onFail": "download"
			}
		]
	},
	"packageManager": "pnpm@10.29.2"
}
